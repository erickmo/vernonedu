APP_NAME=entrepreneurship-api
APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=debug

DATABASE_URL=postgres://postgres:postgres@localhost:5432/entrepreneurship_db?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=300

NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=ENTREPRENEURSHIP_EVENTS

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9090
